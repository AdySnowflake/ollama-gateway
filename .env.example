# ============================================================
# Unified LLM Proxy 配置文件
# 复制此文件为 .env 并填入你的 API Key
# ============================================================

# ---- 服务配置 ----
PORT=11434
HOST=0.0.0.0
# PROXY_API_KEY=your-proxy-api-key  # 可选：代理自身的认证密钥
# CORS_ORIGIN=*                     # 可选：CORS 允许的来源

# ---- OpenAI ----
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=

# ---- Google Gemini ----
GOOGLE_GENERATIVE_AI_API_KEY=

# ---- DeepSeek ----
DEEPSEEK_API_KEY=

# ---- Groq ----
GROQ_API_KEY=

# ---- OpenRouter ----
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- Moonshot (月之暗面) ----
MOONSHOT_API_KEY=
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# ---- 阿里云百炼 ----
BAILIAN_API_KEY=
# BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---- Grok (xAI) ----
GROK_API_KEY=
# GROK_BASE_URL=https://api.x.ai/v1
